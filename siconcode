void handleMagDC_220V() {
  if (manualBoost) {
    Serial.println(">>> [MAG 220V]: MANUAL BOOST LOCKED, SKIP AUTO <<<");
    return;
  }

  currentAC = readCurrentAC();
  currentAC = currentAC - 0.5;
  if (currentAC < 0) {currentAC = 0; }
  float vBatt = getValue(PIN_V1, MULT_V1);

  bool shouldConnect = (currentAC > PRE_CONNECT_A) && (!gridMode) && (vBatt > BATT_LOW_V);

  if (shouldConnect &&!magConnected) {
    digitalWrite(PIN_BOOST, HIGH);
    magConnected = true;
    magStart = millis();
    Serial.printf(">>> [MAG 220V]: ON, I=%.1fA Vbatt=%.1fV <<<\n", currentAC, vBatt);
  }

  bool loadDrop = currentAC < 2.0;
  bool timeout = millis() - magStart > MAG_HOLD_MS;
  bool forceOff = gridMode || (vBatt < BATT_LOW_V - 1.0);

  if (magConnected && ((loadDrop && timeout) || forceOff)) {
    digitalWrite(PIN_BOOST, LOW);
    magConnected = false;
    Serial.println(">>> [MAG 220V]: OFF <<<");
  }
}
