    prefs.putBool("cfg_ok", true);
    prefs.end();
    Serial.printf(">>> SAVED V2: %.1f\n", MULT_V2);
  }
  else if (String(topic) == "saraphi/set/v3") {
    MULT_V3 = newVal;
    prefs.begin("solar_cal", false);
    prefs.putFloat("v3_cal", MULT_V3);
    prefs.putBool("cfg_ok", true);
    prefs.end();
    Serial.printf(">>> SAVED V3: %.1f\n", MULT_V3);
  }
  else if (String(topic) == "saraphi/set/v1_low") {
    vLowLimit = newVal;
    prefs.begin("solar_cal", false);
    prefs.putFloat("vLow", vLowLimit);
    prefs.putBool("cfg_ok", true);
    prefs.end();
    Serial.printf(">>> SAVED vLowLimit: %.1f\n", vLowLimit);
  }
  else if (String(topic) == "saraphi/set/v1_high") {
    vHighLimit = newVal;
    prefs.begin("solar_cal", false);
    prefs.putFloat("vHigh", vHighLimit);
    prefs.putBool("cfg_ok", true);
    prefs.end();
    Serial.printf(">>> SAVED vHighLimit: %.1f\n", vHighLimit);
  }
 else if (String(topic) == "solar/set/vbat_high") {
    vHighThreshold = newVal;
    prefs.begin("solar_cal", false);
    prefs.putFloat("vHighTh", vHighThreshold);
    prefs.putBool("cfg_ok", true);
    prefs.end();
    Serial.printf(">>> SAVED vHighTh: %.1f\n", vHighThreshold);
    return;
  }


  else if (String(topic) == "solar/set/ct_high") {
    ctHighThreshold = newVal;
    prefs.begin("solar_cal", false);
    prefs.putFloat("CTHighTh", ctHighThreshold);
    prefs.putBool("cfg_ok", true);
    prefs.end();
    Serial.printf(">>> SAVED CTHighTh: %.1f\n", ctHighThreshold);
    return;
  }
  else if (String(topic) == "solar/set/ct_low") {
    ctLowThreshold = newVal;
    prefs.begin("solar_cal", false);
    prefs.putFloat("CTLowTh", ctLowThreshold);
    prefs.putBool("cfg_ok", true);
    prefs.end();
    Serial.printf(">>> SAVED CTLowTh: %.1f\n", ctLowThreshold);
    return;
  }

  // 2. รับเวลาจาก Node-RED "09:30"
  if (String(topic) == "saraphi/set/time_start") {
    int h = msg.substring(0, 2).toInt();
    int m = msg.substring(3, 5).toInt();
    if (h >= 0 && h < 24 && m >= 0 && m < 60) {
      startHH = h;
      startMN = m;
      prefs.begin("solar_cal", false);
      prefs.putInt("sHH", startHH);
      prefs.putInt("sMN", startMN);
      prefs.putBool("cfg_ok", true);
      prefs.end();
      Serial.printf(">>> SAVED TIME START: %02d:%02d\n", startHH, startMN);
    }
    return;
  }

  if (String(topic) == "saraphi/set/time_stop") {
    int h = msg.substring(0, 2).toInt();
    int m = msg.substring(3, 5).toInt();
    if (h >= 0 && h < 24 && m >= 0 && m < 60) {
      stopHH = h;
      stopMN = m;
      prefs.begin("solar_cal", false);
      prefs.putInt("tHH", stopHH);
      prefs.putInt("tMN", stopMN);
      prefs.putBool("cfg_ok", true);
      prefs.end();
      Serial.printf(">>> SAVED TIME STOP: %02d:%02d\n", stopHH, stopMN);
      publishTimeStatus();
    }
    return;
  }

  if (String(topic) == "saraphi/set/ntc_offset") {
    NTC_OFFSET = newVal;
    prefs.begin("solar_cal", false);
    prefs.putFloat("ntc_off", NTC_OFFSET);
    prefs.putBool("cfg_ok", true);
    prefs.end();
    Serial.printf(">>> SAVED NTC_OFFSET: %.1f\n", NTC_OFFSET);
    return;
  }

  if (String(topic) == "saraphi/set/rtc_time") {
    setRtcFromMqtt(msg);
    return;
  }

  if (String(topic) == "saraphi/cmd/boost") {
    if (msg == "1" || msg == "ON" || msg == "on") {
      manualBoost = true;
      digitalWrite(PIN_BOOST, HIGH);
      magConnected = true;
      Serial.println(">>> [BOOST]: MANUAL BOOST = 1 (FORCE ON) <<<");
    } else {
      manualBoost = false;
      digitalWrite(PIN_BOOST, LOW);
      magConnected = false;
      Serial.println(">>> [BOOST]: MANUAL BOOST = 0 (AUTO) <<<");
    }
    client.publish("saraphi/status/manual_boost", manualBoost? "1" : "0", true);
    client2.publish("saraphi/status/manual_boost", manualBoost? "1" : "0", true);
    return;
  }

  // 3. คำสั่ง Reboot
  if (String(topic) == "saraphi/cmd/reboot" && msg == "1") {
    lcd.clear();
    lcd.setCursor(0, 0); lcd.print("MQTT REBOOT CMD");
    delay(1000);
    ESP.restart();
  }

  // 4. คำสั่ง Manual INV/PEA/AUTO
  else if (String(topic) == "saraphi/cmd/manual") {
    if (msg == "SW1ON") {
      manualState = true; isCooldown = false;
      digitalWrite(PIN_PEA, HIGH); delay(100); 
      //digitalWrite(PIN_INV, HIGH);
      gridMode = false;
     // lcd.clear(); 
        }
    else if (msg == "SW1OFF") {
      manualState = true; isCooldown = false;
      digitalWrite(PIN_PEA, LOW);
      gridMode = true;
      //  lcd.clear(); 
    }
    else if (msg == "SW2ON") {
      manualState = false;
 
      digitalWrite(PIN_INV, HIGH);
      breakerState = false;
      gridMode = true;
    //    lcd.clear(); 
    }
 else if (msg == "SW2OFF") {
      manualState = false;
 
      digitalWrite(PIN_INV, LOW);
      breakerState = false;
      gridMode = true;
    //    lcd.clear(); 
    }

    showmode();
  }
}

