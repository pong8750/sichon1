void loop() {
  static bool clearDone1 = false;
  static bool clearDone2 = false;
  static unsigned long lastLcdBlink = 0;
  static unsigned long lastWifiTry = 0;
  static bool lastManualStateDrawn = false;
  static bool manualStateInit = false;
  static bool lastGridModeDrawn = true;

  if (WiFi.status()!= WL_CONNECTED && millis() - lastWifiTry > 10000) {
    lastWifiTry = millis();
    WiFi.begin(ssid, password);
    Serial.println(">>> [NET]: Retry WiFi <<<");
  }

  if (!client.connected()) {
    clearDone1 = false;
    reconnect();
  } else if (!clearDone1) {
    client.publish("saraphi/cmd/reboot", "0", true);
    delay(50);
    client.publish("saraphi/cmd/reboot", NULL, true);
    clearDone1 = true;
    Serial.println(">>> [LOOP]: Cleared retained reboot on server1 <<<");
    lcd.setCursor(17,2);
    lcd.printf("M1");
  }

  if (!client2.connected()) {
    clearDone2 = false;
    reconnect();
  } else if (!clearDone2) {
    client2.publish("saraphi/cmd/reboot", "0", true);
    delay(50);
    client2.publish("saraphi/cmd/reboot", NULL, true);
    clearDone2 = true;
    Serial.println(">>> [LOOP]: Cleared retained reboot on server2 <<<");
    lcd.setCursor(19,2);
    lcd.printf("2 ");
  }

  client.loop();
  client2.loop();

  DateTime now = rtc.now();
  handleTimeSetting();

  if (editState == 0) {
    checkManualButton();
    readSensors();
    handleMagDC_220V();

    // … (โค้ดแสดงผล LCD และ publish MQTT ตามที่คุณเขียนไว้) …
  }

  // --- ส่วน publish ทุก 1 วินาที ---
  static unsigned long lastPub = 0;
  if (millis() - lastPub > 1000) {
    lastPub = millis();
    float acAmp = readCurrentAC();
    acAmp = acAmp - 0.5;
    if (acAmp < 0) acAmp = 0;

    float wattValue = acAmp * v1 / 1.63f;
    char wattString[10];
    dtostrf(wattValue, 6, 2, wattString);

    client.publish("saraphi/status/watt", wattString, true);
    client2.publish("saraphi/status/watt", wattString, true);
  }

  calculateWatt(v1, readCurrentAC()); // เรียกฟังก์ชันคำนวณวัตต์
} // ← ปิด loop ที่นี่ครั้งเดียว
