void handleTimeSetting() {
  static unsigned long pressStart = 0;
  static bool wasLongPress = false;
  static unsigned long lastActivity = 0;

  if (editState > 0 && millis() - lastActivity > 30000) {
    editState = 0;
    setHH = 0; setMN = 0; setSC = 0;
    lcd.clear();
    Serial.println(">>> [MENU]: TIMEOUT -> EXIT <<<");
    return;
  }

  if (digitalRead(PIN_SET_MODE) == LOW) {
    if (pressStart == 0) {
      pressStart = millis();
      wasLongPress = false;
      lastActivity = millis();
    }
    if (!wasLongPress && millis() - pressStart > 2000 && editState > 0) {
      wasLongPress = true;
      editState = 0;
      setHH = 0; setMN = 0; setSC = 0;
      lcd.clear();
      lcd.setCursor(0,0); lcd.print("EXIT NO SAVE");
      delay(2000);
      lcd.clear();
      Serial.println(">>> [MENU]: LONG PRESS -> EXIT NO SAVE <<<");
      while(digitalRead(PIN_SET_MODE) == LOW) delay(10);
    }
    if (!wasLongPress && millis() - pressStart > 2000 && editState == 0) {
      wasLongPress = true;
      editState = 6;
      startMN = 0;
      lcd.clear();
      Serial.println(">>> [MENU]: LONG PRESS -> START:HOUR <<<");
      while(digitalRead(PIN_SET_MODE) == LOW) delay(10);
    }
  } else {
    if (pressStart > 0) {
      if (!wasLongPress && millis() - pressStart > 50) {
        lastActivity = millis();
        if (editState == 0) {
          editState = 1;
          DateTime now = rtc.now();
          setHH = now.hour(); setMN = now.minute(); setSC = now.second();
          lcd.clear();
          Serial.println(">>> [MENU]: SHORT PRESS -> CLOCK SETTING <<<");
        } else {
          editState++;
          if (editState > 10) {
            editState = 0;
            setHH = 0; setMN = 0; setSC = 0;
            lcd.clear();
            Serial.println(">>> [MENU]: CIRCLE END -> EXIT NO SAVE <<<");
          } else {
            if (editState == 7) stopMN = 0;
            lcd.clear();
          }
        }
      }
    }
    pressStart = 0;
    wasLongPress = false;
  }

  if (editState > 0) {
    lastActivity = millis();

    if (digitalRead(PIN_SET_UP) == LOW) {
      lastActivity = millis();
      switch(editState) {
        case 1: setHH++; if(setHH > 23) setHH = 0; break;
        case 2: setMN++; if(setMN > 59) setMN = 0; break;
        case 3: setSC++; if(setSC > 59) setSC = 0; break;
        case 4: vLowLimit += 0.5; break;
        case 5: vHighLimit += 0.5; break;
        case 6: startHH++; if(startHH > 23) startHH = 0; break;
        case 7: startMN++; if(startMN > 59) startMN = 0; break;
        case 8: stopHH++; if(stopHH > 23) stopHH = 0; break;
        case 9: stopMN++; if(stopMN > 59) stopMN = 0; break;
      }
      delay(100);
    }

    if (digitalRead(PIN_SET_SAVE) == LOW) {
      delay(50);
      lastActivity = millis();
      if (editState <= 9) {
        switch(editState) {
          case 1: setHH--; if(setHH < 0) setHH = 23; break;
          case 2: setMN--; if(setMN < 0) setMN = 59; break;
          case 3: setSC--; if(setSC < 0) setSC = 59; break;
          case 4: vLowLimit -= 0.5; break;
          case 5: vHighLimit -= 0.5; break;
          case 6: startHH--; if(startHH < 0) startHH = 23; break;
          case 7: startMN--; if(startMN < 0) startMN = 59; break;
          case 8: stopHH--; if(stopHH < 0) stopHH = 23; break;
          case 9: stopMN--; if(stopMN < 0) stopMN = 59; break;
        }
        delay(150);
      }
      else if (editState == 10) {
        if (setHH!= 0 || setMN!= 0 || setSC!= 0) {
          DateTime current = rtc.now();
          rtc.adjust(DateTime(current.year(), current.month(), current.day(), setHH, setMN, setSC));
        }
        prefs.begin("solar_cal", false);
        prefs.putFloat("vLow", vLowLimit);
        prefs.putFloat("vHigh", vHighLimit);
        prefs.putInt("sHH", startHH);
        prefs.putInt("sMN", startMN);
        prefs.putInt("tHH", stopHH);
        prefs.putInt("tMN", stopMN);
        prefs.putBool("cfg_ok", true);
        prefs.end();
        publishTimeStatus(); // <<< เพิ่มบรรทัดนี้ ส่งเวลาไป Node-RED ทันที

        lcd.clear();
        lcd.setCursor(0, 0); lcd.print(" TIME UPDATED ");
        lcd.setCursor(0, 1); lcd.printf("%02d:%02d-%02d:%02d", startHH, startMN, stopHH, stopMN);
        delay(1000);
        editState = 0; setHH = 0; setMN = 0; setSC = 0;
        lcd.clear();
        while(digitalRead(PIN_SET_SAVE) == LOW) delay(10);
      }
    }

    lcd.setCursor(0, 0);
    switch(editState) {
      case 1: lcd.print("1.SET:HH BUTT.UP-DWN"); break;
      case 2: lcd.print("2.SET:MM BUTT.UP-DWN"); break;
      case 3: lcd.print("3.SET:SS BUTT.UP-DWN"); break;
      case 4: lcd.printf("4.SET:V-INV LO %.1fV ", vLowLimit); break;
      case 5: lcd.printf("5.SET:V-INV HI %.1fV ", vHighLimit); break;
      case 6: lcd.printf("6.START:HOUR %02d ", startHH); break;
      case 7: lcd.printf("7.START:MIN %02d ", startMN); break;
      case 8: lcd.printf("8.STOP :HOUR %02d ", stopHH); break;
      case 9: lcd.printf("9.STOP :MIN %02d ", stopMN); break;
      case 10: lcd.print("10.PRESS BUTTON SAVE"); break;//BUTT PIN14  TO SAVE
    }
    lcd.setCursor(0, 1);
    if (editState <= 3) lcd.printf("VAL: %02d:%02d:%02d ", setHH, setMN, setSC);
    else if (editState <= 5) lcd.printf("ADJ: %.1fV [M]EXIT", (editState == 4? vLowLimit : vHighLimit));
    else if (editState <= 9) lcd.printf("ADJ: %02d:%02d [M]EXIT", (editState <= 7? startHH : stopHH), (editState == 7? startMN : stopMN));
    else lcd.printf("%02d:%02d-%02d:%02d ", startHH, startMN, stopHH, stopMN);

    lcd.setCursor(0,2);
    lcd.print("HOLD [M]2s=CANCEL ");
  }
}

