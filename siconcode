void breakerOn() {
  digitalWrite(PIN_STEP_ENA, LOW);  // Enable มอเตอร์
  delay(5); // รอให้ไดรฟ์พร้อม
  digitalWrite(PIN_STEP_DIR, HIGH); // หมุนทาง ON
  
  for(int i=0; i<400; i++){
    digitalWrite(PIN_STEP_PUL, HIGH);
    delayMicroseconds(600);
    digitalWrite(PIN_STEP_PUL, LOW);
    delayMicroseconds(600);
  }
  
  delay(100); // รอให้หยุดนิ่ง
  digitalWrite(PIN_STEP_ENA, HIGH); // Disable ปล่อยฟรี ไม่ร้อน
}

void breakerOff() {
  digitalWrite(PIN_STEP_ENA, LOW);  // Enable มอเตอร์
  delay(5);
  digitalWrite(PIN_STEP_DIR, LOW);  // หมุนทาง OFF
  
  for(int i=0; i<400; i++){
    digitalWrite(PIN_STEP_PUL, HIGH);
    delayMicroseconds(600);
    digitalWrite(PIN_STEP_PUL, LOW);
    delayMicroseconds(600);
  }
  
  delay(100);
  digitalWrite(PIN_STEP_ENA, HIGH); // Disable ปล่อยฟรี
}




