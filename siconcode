float getValue(int pin, float multiplier) {
  long sum = 0;
  int samples = 150;
  for(int i = 0; i < samples; i++) {
    sum += analogRead(pin);
    delayMicroseconds(100);
  }
  return (sum / (float)samples * 3.3 / 4095.0) * multiplier;
}

// <<< ฟังก์ชันอ่านกระแสจาก CT >>>
float readCurrentAC() {
  long sum = 0;
  int samples = 300;
  for(int i = 0; i < samples; i++) {
    int raw = analogRead(PIN_CT);
    int val = raw - 2048;  // <<< จุดที่ 1: 2048 อาจไม่ตรง 0 จริง
    sum += val * val;
    delayMicroseconds(100);
  }
  float rms = sqrt(sum / (float)samples);
  float voltage = rms * 3.3 / 4095.0;
  float current = voltage * CT_RATIO;
  
  // <<< จุดที่ 2: ตัด noise floor ตรงนี้ >>>
  //if (current < 0.5) {  // ถ้าต่ำกว่า 0.5A ให้เป็น 0
  //  current = 0.0;
  //}
  
  return current;
}

//หรือ 1-2k) ที่มีค่า Beta 3950  -40°C ถึง +125°C
void readSensors() {
  v1 = getValue(PIN_V1, MULT_V1);
  v2 = getValue(PIN_V2, MULT_V2);
  v3 = getValue(PIN_V3, MULT_V3);
  int rawNTC = analogRead(NTC_Pin);
  if (rawNTC < 4095 && rawNTC > 100) {
    float v_ratio = rawNTC / 4095.0;
    float R_ntc = 2000.0 * (v_ratio / (1.0 - v_ratio));
    float tempK = 1.0 / (1.0/298.15 + (log(R_ntc/2000.0) / 3950.0));
    tempNTC = (tempK - 273.15) + NTC_OFFSET; // <<< แก้บรรทัดนี้ จาก 15.3 เป็น NTC_OFFSET
  }
  DateTime now = rtc.now();
  Serial.printf("v1:%.1f, v2:%.1f, v3:%.1f, T:%.1f, :%02d:%02d:%02d\n", v1, v2, v3, tempNTC, now.hour(), now.minute(), now.second());
}



